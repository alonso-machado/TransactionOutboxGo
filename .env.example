# ── Postgres ──────────────────────────────────────────────
POSTGRES_PORT=5432
POSTGRES_USER=outbox
POSTGRES_PASSWORD=outbox
POSTGRES_DB=outbox

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
# Maximum times a message is redelivered before routing to its method's DLQ
RABBITMQ_MAX_REDELIVERIES=5

# ── ingestion-api ─────────────────────────────────────────
APP_PORT=8080
# Serve swagger UI at /swagger/index.html. Defaults to true locally (see the
# fallback in docker-compose.yml); production (helmcharts/transaction-outbox/
# values.yaml configMap.data) explicitly sets this to false.
SWAGGER_ENABLED=true

# DispatchOutbox goroutine settings (Transactional Outbox dispatcher)
OUTBOX_DISPATCH_INTERVAL_MS=500
OUTBOX_DISPATCH_BATCH_SIZE=50
OUTBOX_MAX_RETRIES=5
# Hours after which a published outbox row is eligible for pruning
OUTBOX_PRUNE_AFTER_HOURS=48

# Leaky-bucket IP rate limiter (Phase 4 Track 1) — last line of defense behind
# the AWS WAF rate-based rule, the only layer present locally (no ALB/WAF here)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RATE=50
RATE_LIMIT_BURST=100
# Comma-separated CIDRs Gin trusts for X-Forwarded-For (ALB/VPC subnets in
# cloud). Empty locally: no proxy in front, c.ClientIP() uses RemoteAddr directly.
TRUSTED_PROXIES=

# ── consumer-worker ───────────────────────────────────────
CONSUMER_PREFETCH=10

# ── OpenTelemetry ─────────────────────────────────────────
# Per-service name is set directly on each service in docker-compose.yml;
# this default only applies if you run a binary outside Compose.
OTEL_SERVICE_NAME=transaction-outbox-go
# Jaeger's OTLP/HTTP receiver (see the `jaeger` service in docker-compose.yml)
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4318
# Prometheus scrape port for ingestion-api. Each per-method consumer-worker
# (Phase 3 — one per payment method, see docker-compose.yml) exposes its own
# fixed metrics port: consumer-pix=9091, consumer-boleto=9092,
# consumer-transfer=9093, consumer-cartao-credito=9094, consumer-cartao-debito=9095.
METRICS_PORT=9090
