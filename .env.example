# ── Postgres ──────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=outbox
POSTGRES_PASSWORD=outbox
POSTGRES_DB=outbox
# Maximum number of open connections in the GORM pool
POSTGRES_MAX_OPEN_CONNS=20
POSTGRES_MAX_IDLE_CONNS=5

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_AMQP_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
# Exchange / queue names (defaults match code constants)
RABBITMQ_EXCHANGE=outbox.exchange
RABBITMQ_QUEUE=outbox.queue
RABBITMQ_ROUTING_KEY=record.created
RABBITMQ_DLX=outbox.dlx
RABBITMQ_DLQ=outbox.dlq
# Maximum times a message is redelivered before routing to DLQ
RABBITMQ_MAX_REDELIVERIES=5

# ── ingestion-api ─────────────────────────────────────────
APP_PORT=8080

# DispatchOutbox goroutine settings (Transactional Outbox dispatcher)
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRIES=5
# Hours after which a published outbox row is eligible for pruning
OUTBOX_PRUNE_AFTER_HOURS=72

# ── consumer-worker ───────────────────────────────────────
CONSUMER_PREFETCH=10
