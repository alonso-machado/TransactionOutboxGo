{
  "title": "ingestion-api",
  "uid": "ingestion-api",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["transaction-outbox", "ingestion-api"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (RPS)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"ingestion-api\"}[1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latency P50/P95/P99",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{job=\"ingestion-api\"}[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=\"ingestion-api\"}[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=\"ingestion-api\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP status breakdown (2xx/4xx/5xx)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"ingestion-api\", http_response_status_code=~\"2..\"}[1m]))",
          "legendFormat": "2xx"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"ingestion-api\", http_response_status_code=~\"4..\"}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"ingestion-api\", http_response_status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 4,
      "title": "Rate-limiter rejections (429s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "description": "ingestion.ratelimit_rejected_total — Phase 4 Track 1 leaky-bucket meter",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(ingestion_ratelimit_rejected_total{job=\"ingestion-api\"}[1m]))",
          "legendFormat": "429/s"
        }
      ]
    },
    {
      "id": 5,
      "title": "Outbox published rate by method",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (method) (rate(outbox_published_total{job=\"ingestion-api\"}[1m]))",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Outbox pending backlog (NEW + RETRYING)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "outbox_pending_count{job=\"ingestion-api\"}",
          "legendFormat": "pending"
        }
      ]
    },
    {
      "id": 7,
      "title": "Go runtime — goroutines / heap / GC pause",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "go_goroutines{job=\"ingestion-api\"}",
          "legendFormat": "goroutines"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "go_memstats_heap_alloc_bytes{job=\"ingestion-api\"}",
          "legendFormat": "heap_alloc_bytes"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(go_gc_duration_seconds_sum{job=\"ingestion-api\"}[5m])",
          "legendFormat": "gc_pause_rate"
        }
      ]
    }
  ]
}
