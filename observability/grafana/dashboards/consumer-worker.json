{
  "title": "consumer-worker",
  "uid": "consumer-worker",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["transaction-outbox", "consumer-worker"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "method",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(consumer_messages_processed_total, payment_method)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Throughput by method / outcome",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (payment_method, outcome) (rate(consumer_messages_processed_total{payment_method=~\"$method\"}[1m]))",
          "legendFormat": "{{payment_method}} / {{outcome}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Retry attempts rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (payment_method) (rate(consumer_retry_attempts_total{payment_method=~\"$method\"}[1m]))",
          "legendFormat": "{{payment_method}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Retry depth (by retry_count)",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (retry_count) (rate(consumer_retry_attempts_total{payment_method=~\"$method\"}[5m]))",
          "legendFormat": "retry_count={{retry_count}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 4,
      "title": "Poison / DLQ rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "description": "consumer_messages_processed_total{outcome=\"poison_dlq\"} — MAX_DELIVERIES exhausted on a genuine processing error; terminal, never auto-retried again. Non-zero here is an incident — see make replay-dead/drain-dlq.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (payment_method) (rate(consumer_messages_processed_total{payment_method=~\"$method\", outcome=\"poison_dlq\"}[1m]))",
          "legendFormat": "{{payment_method}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Duplicate (redelivery dedup) rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "description": "consumer_messages_processed_total{outcome=\"duplicate\"} — a redelivered message whose (source_message_id, occurred_at) row already existed; absorbed as a no-op and Ack'd immediately, never retried or DLQ'd (see README's Consumer outcome taxonomy). Non-zero is informational, not necessarily an incident — but a sustained climb can mean a consumer is crash-looping before Ack.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (payment_method) (rate(consumer_messages_processed_total{payment_method=~\"$method\", outcome=\"duplicate\"}[1m]))",
          "legendFormat": "{{payment_method}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Queue backlog (ready messages, per method)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "description": "Cross-referenced from the RabbitMQ exporter — queue depth per payments.<method>.queue",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_queue_messages_ready{queue=~\"payments\\\\..*\\\\.queue\"}",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Consumer instances up per method",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "description": "Static 1/method in compose; in cloud this tracks KEDA-driven pod count per Rollout/Deployment (Phase 4 Track 4)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (method) (up{job=\"consumer-worker\"})",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Unknown schema version rate (by version)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "description": "consumer.unknown_schema_version_total{schema_version=...} — pairs with the ticket-severity UnknownSchemaVersion alert (observability/prometheus/rules/alerts.yml). Unlike the generic outcome=\"unknown_schema_version\" bucket in the top panel, this breaks down by the actual bad schemaVersion value seen — useful for spotting a producer/consumer version skew during a rollout.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (schema_version) (rate(consumer_unknown_schema_version_total[5m]))",
          "legendFormat": "schemaVersion={{schema_version}}"
        }
      ]
    }
  ]
}
