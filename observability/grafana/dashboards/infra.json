{
  "title": "infra (RabbitMQ + Postgres)",
  "uid": "infra",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["transaction-outbox", "infra"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "RabbitMQ — per-queue depth (queues + DLQs)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "description": "A poison spike on one shard's DLQ (e.g. events.concert.rock.dlq) is isolated from the others — one queue + DLQ per (stream, event_type, event_subtype)",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_queue_messages{queue=~\"(events|payments)\\\\..*\"}",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "RabbitMQ — publish / deliver / ack rates",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(rabbitmq_queue_messages_published_total{queue=~\"(events|payments)\\\\..*\"}[1m]))",
          "legendFormat": "publish/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(rabbitmq_queue_messages_delivered_total{queue=~\"(events|payments)\\\\..*\"}[1m]))",
          "legendFormat": "deliver/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(rabbitmq_queue_messages_acked_total{queue=~\"(events|payments)\\\\..*\"}[1m]))",
          "legendFormat": "ack/s"
        }
      ]
    },
    {
      "id": 3,
      "title": "RabbitMQ — unacked / consumer count per queue",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_queue_messages_unacked{queue=~\"(events|payments)\\\\..*\"}",
          "legendFormat": "unacked {{queue}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_queue_consumers{queue=~\"(events|payments)\\\\..*\"}",
          "legendFormat": "consumers {{queue}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "RabbitMQ — connections / channels / memory / disk alarms",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_connections",
          "legendFormat": "connections"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_channels",
          "legendFormat": "channels"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_alarms_memory_used_watermark{} or rabbitmq_resident_memory_limit_bytes",
          "legendFormat": "memory_alarm"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_disk_space_available_bytes",
          "legendFormat": "disk_available_bytes"
        }
      ]
    },
    {
      "id": 5,
      "title": "Postgres — connections vs max_connections",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(pg_stat_activity_count)",
          "legendFormat": "connections"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_settings_max_connections",
          "legendFormat": "max_connections"
        }
      ]
    },
    {
      "id": 6,
      "title": "Postgres — TPS (commits + rollbacks)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_xact_commit[1m])) + sum(rate(pg_stat_database_xact_rollback[1m]))",
          "legendFormat": "tps"
        }
      ]
    },
    {
      "id": 7,
      "title": "Postgres — cache hit ratio / deadlocks / longest transaction / DB size",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_blks_hit[5m])) / (sum(rate(pg_stat_database_blks_hit[5m])) + sum(rate(pg_stat_database_blks_read[5m])))",
          "legendFormat": "cache_hit_ratio"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_deadlocks[5m]))",
          "legendFormat": "deadlocks/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(pg_stat_activity_max_tx_duration)",
          "legendFormat": "longest_txn_seconds"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_database_size_bytes",
          "legendFormat": "db_size_bytes {{datname}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "PgBouncer — clients waiting for a connection",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "description": "The headline tile (Phase 5 Track 4.D) — non-zero means the pool is too small for the current KEDA fan-out. Pairs with the PgBouncerClientsWaiting alert (observability/prometheus/rules/alerts.yml).",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pgbouncer_pools_client_waiting_connections",
          "legendFormat": "cl_waiting {{pool_name}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "PgBouncer — max client wait time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "description": "How long the unluckiest queued client waited (maxwait) — pairs with the waiting-clients panel above.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pgbouncer_pools_client_maxwait_seconds",
          "legendFormat": "maxwait {{pool_name}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "PgBouncer — server connections (active / idle / used)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "description": "Actual upstream Postgres connections PgBouncer is holding open — shows the multiplexing win (many clients -> few server conns).",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pgbouncer_pools_server_active_connections",
          "legendFormat": "active {{pool_name}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pgbouncer_pools_server_idle_connections",
          "legendFormat": "idle {{pool_name}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pgbouncer_pools_server_used_connections",
          "legendFormat": "used {{pool_name}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "PgBouncer — client connections (active)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 56 },
      "description": "Inbound load from ingestion-api + the order-/fulfillment-consumer-worker replicas.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pgbouncer_pools_client_active_connections",
          "legendFormat": "active {{pool_name}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "PgBouncer — pooling efficiency (client-active ÷ server-active)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 56 },
      "description": "The collapse ratio PgBouncer buys — the justification panel for running a pooler at all. Higher is better multiplexing.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pgbouncer_pools_client_active_connections / pgbouncer_pools_server_active_connections",
          "legendFormat": "efficiency {{pool_name}}"
        }
      ]
    },
    {
      "id": 14,
      "title": "PgBouncer — avg query / wait time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 64 },
      "description": "Latency added by pooling itself — should stay near zero unless the pool is saturated.",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pgbouncer_stats_avg_query_time",
          "legendFormat": "avg_query_time {{database}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pgbouncer_stats_avg_wait_time",
          "legendFormat": "avg_wait_time {{database}}"
        }
      ]
    }
  ]
}
